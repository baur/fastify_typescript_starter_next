{
  "name": "fastify_typescript",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "start": "tsx src/server.ts",
    "dev": "tsx watch --clear-screen=false src/server.ts",
    "prepare": "lefthook install",
    "hooks:install": "lefthook install",
    "up": "docker compose up -d database",
    "db:new": "node scripts/dbmate.mjs new",
    "db:up": "node scripts/dbmate.mjs up",
    "db:down": "node scripts/dbmate.mjs down",
    "db:status": "node scripts/dbmate.mjs status",
    "migrate": "npm run db:up",
    "check": "biome check .",
    "format": "biome check --write .",
    "test": "npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/under-pressure": "^9.0.3",
    "@scalar/fastify-api-reference": "^1.60.0",
    "close-with-grace": "^2.5.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "kysely": "^0.29.2",
    "pg": "^8.22.0",
    "typebox": "^1.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "dbmate": "^2.33.0",
    "kysely-codegen": "^0.20.0",
    "lefthook": "^2.1.9",
    "pino-pretty": "^13.1.3",
    "standard-version": "^9.5.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
